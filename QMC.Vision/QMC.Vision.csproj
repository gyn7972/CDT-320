  <!--
    HIK MVS x64 런타임을 출력 폴더로 복사.
    프로젝트가 x64 라(MIL.NET 요구) Hik SDK 도 x64 transport 플러그인(MVGigEVisionSDK.dll 등)이 필요한데,
    이 플러그인들은 exe 와 같은 폴더에서 로드된다(PATH 아님). MVS 미설치 머신에선 소스가 비어 자동 skip.
  -->
  <Target Name="CopyMvsRuntimeX64" AfterTargets="Build">
    <ItemGroup>
      <!-- *.dll = transport 플러그인, *.cti = GenTL producer(프레임그래버/OtherDevice 카메라 발견용) -->
      <MvsRuntimeX64 Include="C:\Program Files (x86)\Common Files\MVS\Runtime\Win64_x64\*.dll;C:\Program Files (x86)\Common Files\MVS\Runtime\Win64_x64\*.cti" />
    </ItemGroup>
    <Copy SourceFiles="@(MvsRuntimeX64)" DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" Condition="'@(MvsRuntimeX64)' != ''" />
  </Target>
</Project>